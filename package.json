{
  "name": "content-ownership",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "release": "node scripts/build-release.mjs",
    "typecheck": "tsc --noEmit",
    "i18n:pot": "node scripts/i18n-prepare-js.mjs && ddev exec --dir=/var/www/html wp i18n make-pot wp-content/plugins/content-ownership wp-content/plugins/content-ownership/resources/languages/content-ownership.pot --domain=content-ownership --exclude=vendor,node_modules,dist,tests,.git,.phpunit.cache,resources/assets/js && node scripts/i18n-fix-pot-refs.mjs",
    "i18n:mo": "ddev exec --dir=/var/www/html wp i18n make-mo wp-content/plugins/content-ownership/resources/languages",
    "i18n:json": "ddev exec --dir=/var/www/html wp i18n make-json wp-content/plugins/content-ownership/resources/languages --domain=content-ownership --extensions=tsx,ts,jsx,js --no-purge && node scripts/merge-js-json.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.11",
    "@wordpress/i18n": "^6.19.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-arborist": "^3.7.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.76.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.6.0",
    "vite": "^7.0.5"
  }
}
