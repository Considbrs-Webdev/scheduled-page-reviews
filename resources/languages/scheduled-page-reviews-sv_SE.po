#. Plugin Name of the plugin
#: scheduled-page-reviews.php app/Admin/SettingsPage.php:28
#: app/Admin/SettingsPage.php:29 resources/views/settings-page.php:11
msgid "Scheduled Page Reviews"
msgstr "Schemalagda sidgranskningar"

#. Plugin URI of the plugin
#: scheduled-page-reviews.php
msgid "https://github.com/williamundqvist/scheduled-page-reviews"
msgstr "https://github.com/williamundqvist/scheduled-page-reviews"

#. Description of the plugin
#: scheduled-page-reviews.php
msgid ""
"Per-page review intervals, scheduled page reviews, inheritance, batched cron "
"notifications, and a React-based page-tree admin UI."
msgstr ""
"Granskningsintervall per sida, innehållsägarskap, arv, samlade "
"cron-aviseringar och ett React-baserat sidträd i admin."

#. Author of the plugin
#: scheduled-page-reviews.php
msgid "William Lundqvist"
msgstr "William Undqvist"

