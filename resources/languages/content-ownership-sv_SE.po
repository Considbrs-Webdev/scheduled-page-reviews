msgid "Run scan immediately (recommended when WP-Cron is disabled)"
msgstr "Kör skanning direkt (rekommenderas när WP-Cron är inaktiverat)"

#: resources/assets/js/schedule/ScheduleTab.tsx:50
msgid "Background mode (schedules batched ticks via WP-Cron)"
msgstr "Bakgrundsläge (schemalägger batchade tick via WP-Cron)"

#: resources/assets/js/schedule/ScheduleTab.tsx:56
msgid "Server crontab — sync scan daily at 22:00"
msgstr "Server-crontab — synkron skanning dagligen kl. 22:00"

