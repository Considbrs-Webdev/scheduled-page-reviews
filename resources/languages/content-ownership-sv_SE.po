#: app/Admin/SettingsPage.php:29 resources/views/settings-page.php:11
msgid "Content Ownership"
msgstr "Innehållsägarskap"

#. Plugin URI of the plugin
#: content-ownership.php
msgid "https://github.com/williamundqvist/content-ownership"
msgstr "https://github.com/williamundqvist/content-ownership"

#. Description of the plugin
#: content-ownership.php
msgid ""
"Per-page review intervals, content ownership, inheritance, batched cron "
"notifications, and a React-based page-tree admin UI."
msgstr ""
"Granskningsintervall per sida, innehållsägarskap, arv, samlade "
"cron-aviseringar och ett React-baserat sidträd i admin."

