#. Plugin Name of the plugin
#: content-ownership.php
#: app/Admin/SettingsPage.php:28
#: app/Admin/SettingsPage.php:29
#: resources/views/settings-page.php:11
msgid "Content Ownership"
msgstr "Innehållsägarskap"

#. Plugin URI of the plugin
#: content-ownership.php
msgid "https://github.com/williamundqvist/content-ownership"
msgstr "https://github.com/williamundqvist/content-ownership"

#. Description of the plugin
#: content-ownership.php
msgid "Per-page review intervals, content ownership, inheritance, batched cron notifications, and a React-based page-tree admin UI."
msgstr "Granskningsintervall per sida, innehållsägarskap, arv, samlade cron-aviseringar och ett React-baserat sidträd i admin."

#. Author of the plugin
#: content-ownership.php
msgid "William Undqvist"
msgstr "William Undqvist"

#: app/Admin/DashboardWidget.php:37
msgid "Content ownership — pages needing review"
msgstr "Innehållsägarskap — sidor som behöver granskas"

#: app/Admin/DashboardWidget.php:51
msgid "No pages on the site need review right now."
msgstr "Inga sidor på webbplatsen behöver granskas just nu."

#: app/Admin/DashboardWidget.php:52
msgid "Nothing assigned to you needs review right now. Nice work!"
msgstr "Inget som är tilldelat dig behöver granskas just nu. Bra jobbat!"

#: app/Admin/DashboardWidget.php:62
msgid "Overdue"
msgstr "Försenad"

#: app/Admin/DashboardWidget.php:69
msgid "Due soon"
msgstr "Snart dags"

#: app/Admin/DashboardWidget.php:131
msgid "(no title)"
msgstr "(saknar titel)"

#: app/Admin/DashboardWidget.php:152
msgid "Open content ownership settings →"
msgstr "Öppna inställningar för innehållsägarskap →"

#. translators: %d = maximum number of list items shown
#: app/Admin/DashboardWidget.php:159
#, php-format
msgid "(showing first %d)"
msgstr "(visar de första %d)"

#: app/Admin/DashboardWidget.php:184
#: app/Admin/DashboardWidget.php:193
msgid "due today"
msgstr "ska granskas idag"

#. translators: %d = number of days
#: app/Admin/DashboardWidget.php:187
#, php-format
msgid "%d day overdue"
msgid_plural "%d days overdue"
msgstr[0] "%d dag försenad"
msgstr[1] "%d dagar försenade"

#. translators: %d = number of days
#: app/Admin/DashboardWidget.php:196
#, php-format
msgid "due in %d day"
msgid_plural "due in %d days"
msgstr[0] "ska granskas om %d dag"
msgstr[1] "ska granskas om %d dagar"

#: app/Admin/PostStates.php:66
msgid "Review overdue"
msgstr "Granskning försenad"

#: app/Admin/PostStates.php:70
msgid "Review due soon"
msgstr "Granskning snart dags"

#: app/Admin/RowActions.php:46
msgid "Mark reviewed"
msgstr "Markera som granskad"

#: app/Admin/RowActions.php:57
msgid "Invalid request."
msgstr "Ogiltig begäran."

#: app/Admin/RowActions.php:63
msgid "You do not have permission to mark this page as reviewed."
msgstr "Du har inte behörighet att markera den här sidan som granskad."

#. translators: %s = page title
#: app/Admin/RowActions.php:89
#, php-format
msgid "Marked \"%s\" as reviewed."
msgstr "Markerade \"%s\" som granskad."

#: app/Rest/MarkReviewedController.php:45
msgid "You must be logged in to mark a page as reviewed."
msgstr "Du måste vara inloggad för att markera en sida som granskad."

#: app/Rest/PageRuleController.php:73
msgid "Request body must be a JSON object."
msgstr "Begäransinnehållet måste vara ett JSON-objekt."

#: content-ownership.php:29
msgid "Content Ownership: Composer dependencies are missing. Please run \"composer install\" inside the plugin directory."
msgstr "Innehållsägarskap: Composer-beroenden saknas. Kör \"composer install\" i plugin-katalogen."

#: resources/views/settings-page.php:16
msgid "This page requires JavaScript."
msgstr "Den här sidan kräver JavaScript."
